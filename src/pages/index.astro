---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import RepoCard from "../components/RepoCard.astro";

const links = [
  { label: "GitHub", url: "https://github.com/J0nasW" },
  { label: "LinkedIn", url: "https://linkedin.com/in/jonas-wilinski-a31a35143/" },
  { label: "Bluesky", url: "https://bsky.app/profile/jonashw.bsky.social" },
  { label: "HuggingFace", url: "https://huggingface.co/J0nasW" },
  { label: "ORCID", url: "https://orcid.org/0009-0005-4672-7197" },
];

const techStack = [
  "Python",
  "TypeScript",
  "PyTorch",
  "DuckDB",
  "LLMs",
  "NLP",
  "Astro",
  "Docker",
];

const repos = [
  {
    name: "science-datalake",
    description:
      "Unified data lake of 293M+ scientific papers from 8 scholarly sources + 13 ontologies (960 GB Parquet, queryable via DuckDB).",
    tags: ["python", "duckdb", "parquet", "nlp", "scisci"],
    url: "https://j0nasw.github.io/science-datalake/",
    badge: "960 GB",
  },
  {
    name: "claude-paper-review",
    description:
      "6-agent pre-submission referee report skill for Claude Code. Supports 12 academic venues with venue-specific review criteria.",
    tags: ["claude-code", "skill", "academic", "review"],
    url: "https://github.com/J0nasW/claude-paper-review",
    badge: "6 agents",
  },
];
---

<BaseLayout>
  <div class="container">
    <Header />

    <section class="hero">
      <h1 class="hero-name">
        Jonas Wilinski<span class="accent">.</span>
      </h1>
      <p class="hero-role">PhD Candidate & Developer — TU Hamburg</p>
      <p class="hero-bio">
        Researching the diffusion of AI concepts across the global scientific
        landscape using Natural Language Processing and Large Language Models.
        Building open-source tools for the scientific ecosystem.
      </p>

      <div class="hero-stack">
        {techStack.map((t) => <span>{t}</span>)}
      </div>

      <div class="hero-links">
        {
          links.map((l) => (
            <a href={l.url} target="_blank" rel="noopener noreferrer">
              {l.label}
            </a>
          ))
        }
      </div>

      <span class="cursor" aria-hidden="true">_</span>
    </section>

    <span class="section-label">// projects</span>

    <div class="projects-grid">
      {
        repos.map((r) => (
          <RepoCard
            name={r.name}
            description={r.description}
            tags={r.tags}
            url={r.url}
            badge={r.badge}
          />
        ))
      }
    </div>

    <Footer />
  </div>
</BaseLayout>

<style>
  .hero {
    padding: 2rem 0 2.5rem;
    border-bottom: 1px dashed var(--border);
    margin-bottom: 0.5rem;
  }

  .hero-name {
    font-size: 2rem;
    font-weight: 600;
    color: var(--text-bright);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .accent {
    color: var(--accent);
  }

  .hero-role {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-dim);
    font-weight: 300;
  }

  .hero-bio {
    margin-top: 1.25rem;
    font-size: 0.85rem;
    color: var(--text);
    line-height: 1.7;
    max-width: 600px;
  }

  .hero-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.25rem;
  }

  .hero-stack span {
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    background: var(--tag-bg);
    color: var(--tag-text);
    border: 1px solid var(--border);
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1rem;
    margin-top: 1.25rem;
    font-size: 0.75rem;
  }

  .hero-links a {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.15s;
  }

  .hero-links a:hover {
    color: var(--accent);
  }

  .hero-links a::before {
    content: "~ ";
    color: var(--accent-dim);
    font-weight: 600;
  }

  .cursor {
    display: inline-block;
    margin-top: 1.25rem;
    color: var(--accent);
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  .section-label {
    display: block;
    margin-top: 3rem;
    margin-bottom: 1rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-dim);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 0.75rem;
  }

  @media (max-width: 680px) {
    .hero-name {
      font-size: 1.5rem;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
