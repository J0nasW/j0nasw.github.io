---
interface Props {
  name: string;
  description: string;
  tags: string[];
  url: string;
  badge?: string;
}

const { name, description, tags, url, badge } = Astro.props;
---

<a
  class="repo-card"
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  data-umami-event={`click--${name}`}
>
  <div class="repo-header">
    <span class="repo-name">{name}</span>
    {badge && <span class="repo-badge">{badge}</span>}
  </div>
  <p class="repo-desc">{description}</p>
  <div class="repo-tags">
    {tags.map((t) => <span>{t}</span>)}
  </div>
</a>

<style>
  .repo-card {
    display: block;
    padding: 1.25rem 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    border-radius: 6px;
    transition:
      border-color 0.2s,
      background 0.2s;
  }

  .repo-card:hover {
    border-color: var(--border-hover);
    background: #131313;
  }

  .repo-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .repo-name {
    font-weight: 600;
    color: var(--text-bright);
    font-size: 0.9rem;
  }

  .repo-name::before {
    content: "~/";
    color: var(--accent);
    font-weight: 400;
  }

  .repo-badge {
    font-size: 0.65rem;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    background: var(--accent-dim);
    color: var(--accent);
    white-space: nowrap;
  }

  .repo-desc {
    font-size: 0.8rem;
    color: var(--text);
    margin-top: 0.35rem;
    line-height: 1.6;
  }

  .repo-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.6rem;
  }

  .repo-tags span {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    background: var(--tag-bg);
    color: var(--tag-text);
  }
</style>
